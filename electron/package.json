{
  "name": "nfse-automacao",
  "version": "2.3.0",
  "description": "Automação NFSe com Electron + FastAPI",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "dev:renderer": "vite",
    "build:renderer": "vite build",
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "start": "electron .",
    "build": "npm run build:renderer && electron-builder"
  },
  "keywords": ["nfse", "automacao", "certificado"],
  "author": "CONX Contabilidade",
  "license": "proprietary",
  "dependencies": {
    "framer-motion": "^11.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.6.4",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.conx.nfse-automacao",
    "productName": "NFSe Automacao",
    "files": [
      "main.js",
      "preload.js",
      "renderer-dist/**/*",
      "../api/**/*",
      "../*.py",
      "../config.py"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
