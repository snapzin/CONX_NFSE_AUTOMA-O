# -----------------------------------------------------------------------------
# PORTAL NFSE / PLAYWRIGHT
# -----------------------------------------------------------------------------
NFSE_LOGIN_URL = "https://seu-portal-nfse.gov.br/"
NFSE_EMITIDAS_URL = "https://seu-portal-nfse.gov.br/consulta-notas"

# Use padroes separados por virgula.
# Exemplo: "https://seu-portal-nfse.gov.br/*,https://*.prefeitura.gov.br/*"
AUTOSELECT_CERTIFICATE_PATTERNS = "https://seu-portal-nfse.gov.br/*"

# Se vazio, usa navegador Chromium bundled do Playwright.
CHROME_EXECUTABLE_PATH = ""

# "chromium" recomendado para extensoes em Playwright.
CHROME_CHANNEL = "chromium"

PLAYWRIGHT_HEADLESS = False
PLAYWRIGHT_TIMEOUT_MS = 60000
PLAYWRIGHT_SLOW_MO_MS = 0
PLAYWRIGHT_LOGIN_TIMEOUT_S = 45
PLAYWRIGHT_DOWNLOAD_TIMEOUT_S = 180
PLAYWRIGHT_EXTENSION_TIMEOUT_S = 30

# -----------------------------------------------------------------------------
